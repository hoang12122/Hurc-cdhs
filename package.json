{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx tsx src/scripts/local-preflight.ts && next dev",
    "build": "npx tsx src/scripts/build-env-guard.ts && npm run db:generate:all && next build",
    "db:generate:all": "npx prisma generate --schema=prisma/auth/schema.prisma && npx prisma generate --schema=prisma/ai/schema.prisma && npx prisma generate --schema=prisma/metro/schema.prisma && npx prisma generate --schema=prisma/ops/schema.prisma",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check-updates": "ncu",
    "migrate": "npx tsx src/scripts/migrate-json-to-pg.ts",
    "db:ops:migrate": "npx tsx src/scripts/safe-migrate.ts ops",
    "db:ai:migrate": "npx tsx src/scripts/safe-migrate.ts ai",
    "db:ops:generate": "npx prisma generate --schema=prisma/ops/schema.prisma",
    "db:ai:generate": "npx prisma generate --schema=prisma/ai/schema.prisma",
    "db:ops:status": "npx prisma migrate status --schema=prisma/ops/schema.prisma",
    "db:check:integrity": "npx tsx src/scripts/run-integrity-checks.ts",
    "test:db": "npx tsx src/scripts/test-multi-db.ts",
    "test:mock": "npx tsx src/scripts/test-mock-layer.ts",
    "test:integrity": "npx tsx src/scripts/test-cross-db-integrity.ts",
    "test:graph": "npx tsx src/scripts/test-trustgraph-sync.ts",
    "db:dashboard": "npx tsx src/scripts/generate-integrity-dashboard.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.10.0",
    "@huggingface/inference": "^4.13.15",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.417.0",
    "mammoth": "^1.12.0",
    "mongodb": "^7.2.0",
    "net-snmp": "^3.7.1",
    "next": "^14.2.35",
    "nodemailer": "^8.0.6",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.4",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "npm-check-updates": "^22.0.1",
    "postcss": "^8.4.40",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
