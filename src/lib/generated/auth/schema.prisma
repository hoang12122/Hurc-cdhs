generator client {
  provider = "prisma-client-js"
  output   = "../../src/lib/generated/auth"
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DATABASE_URL")
}

model User {
  id                    String    @id
  name                  String
  email                 String    @unique
  password              String?
  role                  String // References Role.id
  status                String // 'active' | 'inactive'
  department            String?
  isVerified            Boolean   @default(false)
  passwordLastChangedAt DateTime? @default(now())
  permissions           String[]  @default([])
  assignedSubsystems    String[]  @default([])
  avatarUrl             String?
  verificationOtp       String?
  otpExpiry             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Role {
  id          String   @id
  name        String
  description String
  permissions String[] @default([])

  @@map("roles")
}

model PasswordResetRequest {
  id        String   @id
  userId    String
  userEmail String
  userName  String
  status    String // 'pending' | 'approved' | 'rejected'
  createdAt DateTime @default(now())

  @@map("password_reset_requests")
}
