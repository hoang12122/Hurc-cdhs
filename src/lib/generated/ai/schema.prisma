generator client {
  provider = "prisma-client-js"
  output   = "../../src/lib/generated/ai"
}

datasource db {
  provider = "postgresql"
  url      = env("AI_DATABASE_URL")
}

model AiAgent {
  id           String   @id @default(cuid())
  name         String
  subsystem    String // 'Signaling', 'Power', 'Track', etc.
  systemPrompt String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("ai_agents")
}

model AiKnowledgeSnippet {
  id        String   @id @default(cuid())
  content   String
  source    String // e.g., 'Manual', 'Email', 'LocalSend'
  tags      String[] @default([])
  createdAt DateTime @default(now())
  agentId   String? // Optional: link to a specific agent

  @@map("ai_knowledge_snippets")
}
